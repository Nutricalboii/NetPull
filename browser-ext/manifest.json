{
  "manifest_version": 3,
  "name": "NetPull Link Grabber",
  "version": "1.0",
  "description": "Send links to NetPull Download Manager",
  "permissions": [
    "contextMenus",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/icon48.png"
  }
}
